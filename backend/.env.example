# Copy this file to `.env` and replace the placeholder values.

PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=school_portal

# Used to sign auth tokens.
AUTH_SECRET=replace_with_a_long_random_value

# Optional: set to 1 to run without a live database.
DEMO_MODE=0
